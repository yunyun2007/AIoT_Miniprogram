.container {
  padding: 30rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.speed-section {
  text-align: center;
  padding: 60rpx 0;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 20rpx;
  margin-bottom: 30rpx;
}

.speed-value {
  font-size: 120rpx;
  font-weight: bold;
  color: #fff;
}

.speed-unit {
  font-size: 32rpx;
  color: rgba(255,255,255,0.8);
}

.data-grid {
  display: flex;
  justify-content: space-around;
  background: #fff;
  padding: 40rpx 0;
  border-radius: 20rpx;
  margin-bottom: 30rpx;
}

.data-item {
  text-align: center;
}

.data-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  display: block;
}

.data-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.control-section {
  display: flex;
  gap: 20rpx;
}

.btn-start, .btn-pause, .btn-stop {
  flex: 1;
  height: 100rpx;
  line-height: 100rpx;
  border-radius: 50rpx;
  font-size: 36rpx;
  color: #fff;
  border: none;
}

.btn-start { background: #07c160; }
.btn-pause { background: #ff9500; }
.btn-stop { background: #ff3b30; }

.today-summary {
  margin-top: 40rpx;
  text-align: center;
  color: #666;
}