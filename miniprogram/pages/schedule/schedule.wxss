/* 顶部栏 */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
  background: #fff;
  border-bottom: 1rpx solid #eee;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

/* 星期标题 */
.week-header {
  display: flex;
  background: #f8f8f8;
  border-bottom: 1rpx solid #ddd;
  height: 100rpx;
  align-items: center;
}

.time-column {
  width: 100rpx;
  flex-shrink: 0;
}

.day-column {
  flex: 1;
  text-align: center;
  padding: 10rpx 0;
  border-left: 1rpx solid #eee;
}

.day-column.active {
  background: #e6f7ff;
}

.day-name {
  display: block;
  font-size: 26rpx;
  color: #666;
}

.day-number {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

/* 课表主体 */
.schedule-body {
  height: calc(100vh - 200rpx);
  background: #fff;
}

.schedule-grid {
  display: flex;
  min-height: 100%;
}

.time-slots {
  width: 100rpx;
  flex-shrink: 0;
  background: #fafafa;
  border-right: 1rpx solid #eee;
}

.time-slot {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-bottom: 1rpx solid #f0f0f0;
  font-size: 22rpx;
  color: #999;
  height: 140rpx;
}

.slot-number {
  font-size: 20rpx;
  color: #ccc;
  margin-top: 4rpx;
}

/* 课程列 */
.course-columns {
  display: flex;
  flex: 1;
}

.course-columns .day-column {
  flex: 1;
  border-left: 1rpx solid #f0f0f0;
}

.course-columns .day-column.active {
  background: #f0f9ff;
}

.course-cell {
  border-bottom: 1rpx solid #f5f5f5;
  padding: 8rpx;
  box-sizing: border-box;
  position: relative;
  transition: all 0.2s;
}

.course-cell:active {
  background: #f5f5f5;
}

.course-cell.has-course {
  padding: 4rpx;
}

.course-content {
  height: 100%;
  border-radius: 8rpx;
  padding: 8rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  box-sizing: border-box;
}

.course-name {
  font-size: 24rpx;
  font-weight: 500;
  color: #fff;
  line-height: 1.3;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.course-location {
  font-size: 20rpx;
  color: rgba(255,255,255,0.9);
  margin-top: 6rpx;
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.empty-cell {
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 颜色主题 */
.course-cell.blue .course-content { background: #4a90d9; }
.course-cell.green .course-content { background: #5cb85c; }
.course-cell.orange .course-content { background: #f0ad4e; }
.course-cell.red .course-content { background: #d9534f; }
.course-cell.purple .course-content { background: #9b59b6; }
.course-cell.teal .course-content { background: #1abc9c; }

/* 弹窗样式 */
.popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
}

.popup-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.popup-body {
  max-height: calc(75vh - 200rpx);
  padding-bottom: 40rpx;
}

.location-display {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  max-width: 400rpx;
}

.location-text {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.location-coords {
  font-size: 22rpx;
  color: #07c160;
  margin-top: 4rpx;
  font-family: monospace;
}

.placeholder {
  color: #999;
  font-size: 28rpx;
}

/* 颜色选择器 */
.color-picker {
  display: flex;
  gap: 20rpx;
  padding: 20rpx 0;
}

.color-item {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  border: 4rpx solid transparent;
}

.color-item.selected {
  border-color: #333;
  transform: scale(1.1);
}

.color-item.blue { background: #4a90d9; }
.color-item.green { background: #5cb85c; }
.color-item.orange { background: #f0ad4e; }
.color-item.red { background: #d9534f; }
.color-item.purple { background: #9b59b6; }
.color-item.teal { background: #1abc9c; }

.popup-actions {
  padding: 30rpx;
  margin-top: 20rpx;
}