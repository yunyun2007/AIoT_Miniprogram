<view class="container">
  <!-- 云端连接状态 -->
  <view class="cloud-status" wx:if="{{cloudConnected}}">
    <van-icon name="cloud" size="16" color="#07c160" />
    <text class="cloud-text">云端已连接</text>
  </view>
  <view class="cloud-status offline" wx:else>
    <van-icon name="cloud-o" size="16" color="#999" />
    <text class="cloud-text">云端未连接</text>
  </view>

  <!-- 实时速度（大数字） -->
  <view class="speed-section">
    <view class="speed-value">{{speed}}</view>
    <text class="speed-unit">km/h</text>
  </view>

  <!-- 数据网格 -->
  <view class="data-grid">
    <view class="data-item">
      <text class="data-value">{{distance}}</text>
      <text class="data-label">公里</text>
    </view>
    <view class="data-item">
      <text class="data-value">{{durationText || '00:00:00'}}</text>
      <text class="data-label">时长</text>
    </view>
    <view class="data-item">
      <text class="data-value">{{calories}}</text>
      <text class="data-label">千卡</text>
    </view>
    <view class="data-item">
      <text class="data-value">{{avgSpeed || 0}}</text>
      <text class="data-label">均速</text>
    </view>
  </view>

  <!-- 云端IMU数据（骑行时显示） -->
  <view class="imu-section" wx:if="{{showCloudData && isTracking}}">
    <view class="section-title">传感器数据</view>
    <view class="imu-grid">
      <view class="imu-item">
        <text class="imu-label">加速度X</text>
        <text class="imu-value">{{accelerationXText}} m/s²</text>
      </view>
      <view class="imu-item">
        <text class="imu-label">加速度Y</text>
        <text class="imu-value">{{accelerationYText}} m/s²</text>
      </view>
      <view class="imu-item">
        <text class="imu-label">加速度Z</text>
        <text class="imu-value">{{accelerationZText}} m/s²</text>
      </view>
      <view class="imu-item">
        <text class="imu-label">加速度幅值</text>
        <text class="imu-value {{magnitude > 25 ? 'warning' : ''}}">{{magnitude}} m/s²</text>
      </view>
    </view>
    <view class="imu-grid">
      <view class="imu-item">
        <text class="imu-label">横滚角</text>
        <text class="imu-value">{{rollText}}°</text>
      </view>
      <view class="imu-item">
        <text class="imu-label">俯仰角</text>
        <text class="imu-value">{{pitchText}}°</text>
      </view>
      <view class="imu-item">
        <text class="imu-label">偏航角</text>
        <text class="imu-value">{{yawText}}°</text>
      </view>
    </view>
  </view>

  <!-- 课程提醒卡片 (课前20分钟显示) -->
  <view class="reminder-card" wx:if="{{reminderCourse}}" bindtap="goToNavigation">
    <view class="reminder-header">
      <van-icon name="clock" size="20" color="#ff6b35" />
      <text class="reminder-title">即将上课</text>
      <text class="reminder-time">{{reminderMinutes}}分钟后</text>
    </view>

    <view class="reminder-course">
      <text class="course-name">{{reminderCourse.name}}</text>
      <text class="course-location">{{reminderCourse.locationName}}</text>
    </view>

    <view class="reminder-info">
      <text class="course-time">{{reminderCourse.startTime}} - {{reminderCourse.endTime}}</text>
      <text class="course-distance" wx:if="{{reminderDistance !== null}}">
        距离 {{reminderDistance}} 米
      </text>
      <text class="course-distance" wx:else>距离 -- 米</text>
    </view>

    <view class="reminder-action">
      <van-button type="warning" size="small" round>
        一键导航
      </van-button>
    </view>

    <view class="reminder-dismiss" bindtap="dismissReminder">
      <van-icon name="cross" size="16" color="#999" />
    </view>
  </view>

  <!-- 导航卡片 -->
  <view class="nav-card" bindtap="goToNavigation">
    <view class="nav-card-icon">
      <van-icon name="guide-o" size="40" color="{{navStatus === 'navigating' ? '#07c160' : '#999'}}" />
    </view>
    <view class="nav-card-content">
      <text class="nav-card-title">{{navDestination || '导航'}}</text>
      <text class="nav-card-hint">{{navStatus === 'navigating' ? navInstruction : '点击设置目的地'}}</text>
    </view>
    <van-icon name="arrow" color="#ccc" />
  </view>

  <!-- 防盗模式入口 -->
  <view class="anti-theft-card" bindtap="goToAntiTheft">
    <view class="anti-theft-icon">
      <van-icon name="warning-o" size="40" color="#ff6b35" />
    </view>
    <view class="anti-theft-content">
      <text class="anti-theft-title">防盗模式</text>
      <text class="anti-theft-hint">监控设备位置，异常移动提醒</text>
    </view>
    <van-icon name="arrow" color="#ccc" />
  </view>

  <!-- 控制按钮 -->
  <view class="control-section">
    <block wx:if="{{!isTracking}}">
      <button class="btn-start" bindtap="startRide">开始骑行</button>
    </block>
    <block wx:else>
      <button class="btn-pause" bindtap="togglePause">
        {{isPaused ? '继续' : '暂停'}}
      </button>
      <button class="btn-stop" bindtap="stopRide">结束</button>
    </block>
  </view>

  <!-- 今日累计 -->
  <view class="today-summary" wx:if="{{!isTracking && distance > 0}}">
    <text>今日累计：{{distance}} 公里 | {{calories}} 千卡</text>
    <button class="btn-link" bindtap="viewMap">查看轨迹</button>
  </view>
</view>