.container {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.card-date, .month-tag {
  font-size: 24rpx;
  color: #999;
}

.more-link {
  font-size: 26rpx;
  color: #07c160;
}

/* 今日概览 */
.today-stats {
  display: flex;
  align-items: center;
  padding: 30rpx;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-item.main {
  flex: 1.5;
}

.stat-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  display: block;
}

.stat-item.main .stat-value {
  font-size: 72rpx;
  color: #07c160;
}

.stat-unit {
  font-size: 22rpx;
  color: #999;
  margin-left: 4rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #666;
  display: block;
  margin-top: 8rpx;
}

.stat-divider {
  width: 1rpx;
  height: 80rpx;
  background: #eee;
}

/* 图表 */
.chart-container {
  padding: 30rpx;
  height: 300rpx;
}

.chart-bars {
  display: flex;
  justify-content: space-around;
  align-items: flex-end;
  height: 100%;
}

.bar-group {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.bar-wrapper {
  display: flex;
  align-items: flex-end;
  gap: 8rpx;
  height: 240rpx;
}

.bar {
  width: 24rpx;
  border-radius: 4rpx;
  min-height: 4rpx;
  transition: height 0.3s;
}

.bar.distance {
  background: #07c160;
}

.bar.duration {
  background: #ff9500;
}

.bar-label {
  font-size: 22rpx;
  color: #999;
  margin-top: 12rpx;
}

.chart-legend {
  display: flex;
  gap: 20rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 22rpx;
  color: #666;
}

.legend-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 4rpx;
}

/* 月度统计 */
.month-grid {
  display: flex;
  padding: 30rpx 0;
}

.month-item {
  flex: 1;
  text-align: center;
  border-right: 1rpx solid #f0f0f0;
}

.month-item:last-child {
  border-right: none;
}

.month-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  display: block;
}

.month-unit {
  font-size: 20rpx;
  color: #999;
}

.month-label {
  font-size: 22rpx;
  color: #666;
  display: block;
  margin-top: 8rpx;
}

/* 历史记录 */
.history-list {
  padding: 0 30rpx;
}

.history-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.history-item:last-child {
  border-bottom: none;
}

.history-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.history-date {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 80rpx;
  margin-right: 20rpx;
}

.history-date .day {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

.history-date .month {
  font-size: 20rpx;
  color: #999;
}

.history-info {
  flex: 1;
}

.history-title {
  font-size: 30rpx;
  color: #333;
  display: block;
}

.history-time {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

.history-right {
  text-align: right;
}

.history-distance {
  font-size: 32rpx;
  font-weight: bold;
  color: #07c160;
  display: block;
}

.history-duration {
  font-size: 22rpx;
  color: #999;
}

.empty-tip {
  text-align: center;
  padding: 60rpx;
  color: #999;
}

/* 个人最佳 */
.pb-list {
  padding: 0 30rpx;
}

.pb-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.pb-item:last-child {
  border-bottom: none;
}

.pb-info {
  flex: 1;
  margin-left: 20rpx;
}

.pb-label {
  font-size: 26rpx;
  color: #666;
  display: block;
}

.pb-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.pb-date {
  font-size: 22rpx;
  color: #999;
}

/* AI 报告卡片 */
.ai-report-card .card-header {
  border-bottom: none;
}

.ai-report-card .card-header .van-icon {
  margin-right: 8rpx;
}

.ai-report-time {
  font-size: 22rpx;
  color: #999;
}

.ai-report-content {
  padding: 0 30rpx 30rpx;
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
  white-space: pre-wrap;
}

.ai-generate-btn {
  padding: 30rpx;
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.ai-generate-btn .van-button {
  width: 100%;
}