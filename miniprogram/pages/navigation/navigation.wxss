.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 20rpx;
}

.search-section {
  background: #fff;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.suggestions {
  background: #fff;
  border-radius: 12rpx;
  margin-top: 20rpx;
  overflow: hidden;
}

.suggestion-item {
  padding: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.suggestion-item:last-child {
  border-bottom: none;
}

.suggestion-main {
  display: flex;
  align-items: center;
}

.suggestion-text {
  margin-left: 16rpx;
  flex: 1;
}

.suggestion-title {
  display: block;
  font-size: 28rpx;
  color: #333;
}

.suggestion-address {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.destination-section {
  background: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-top: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.destination-card {
  display: flex;
  align-items: center;
}

.destination-info {
  margin-left: 20rpx;
  flex: 1;
}

.destination-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.destination-address {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-top: 8rpx;
}

.destination-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
}

.btn-nav-start,
.btn-nav-app {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.btn-nav-start {
  background: #07c160;
  color: #fff;
}

.btn-nav-app {
  background: #f0f0f0;
  color: #333;
}

.nav-driving {
  background: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-top: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.nav-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.nav-destination {
  flex: 1;
}

.nav-label {
  display: block;
  font-size: 24rpx;
  color: #999;
}

.nav-value {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-top: 8rpx;
}

.btn-cancel {
  padding: 16rpx 32rpx;
  background: #f5f5f5;
  color: #666;
  border-radius: 32rpx;
  font-size: 26rpx;
}

.nav-instruction-card {
  background: linear-gradient(135deg, #07c160, #04a34b);
  border-radius: 16rpx;
  padding: 40rpx;
  color: #fff;
  text-align: center;
  margin-bottom: 30rpx;
}

.nav-turn-text {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.nav-distance {
  display: flex;
  justify-content: center;
  align-items: baseline;
}

.distance-value {
  font-size: 72rpx;
  font-weight: bold;
}

.distance-unit {
  font-size: 28rpx;
  margin-left: 10rpx;
}

.nav-info {
  padding: 20rpx 0;
}

.nav-info-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 24rpx;
  color: #666;
}

.empty-hint {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-text {
  display: block;
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #999;
}
