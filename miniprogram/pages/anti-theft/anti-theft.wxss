.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 20rpx;
}

/* 模式切换标签 */
.mode-tabs {
  display: flex;
  background: #fff;
  border-radius: 12rpx;
  padding: 8rpx;
  margin-bottom: 20rpx;
}

.mode-tab {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 20rpx 0;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #666;
  transition: all 0.3s;
}

.mode-tab.active {
  background: #07c160;
  color: #fff;
}

/* 设备地图 */
.device-map-container {
  position: relative;
  width: 100%;
  height: 400rpx;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.device-map {
  width: 100%;
  height: 100%;
}

.map-status-tag {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 30rpx;
  padding: 10rpx 20rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: #333;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.status-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #999;
}

.status-dot.moving {
  background: #ff3b30;
  animation: pulse 1s infinite;
}

.status-dot.stationary {
  background: #07c160;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

/* 设备信息卡片 */
.device-info-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.info-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
}

.info-label {
  font-size: 28rpx;
  color: #999;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.status-indicator {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #999;
}

.status-indicator.offline {
  background: #999;
}

.status-indicator.stationary {
  background: #07c160;
}

.status-indicator.moving {
  background: #ff3b30;
}

.location-text {
  max-width: 380rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.btn-locate {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  margin-top: 20rpx;
  padding: 16rpx 0;
  background: #f5f5f5;
  border-radius: 40rpx;
  font-size: 28rpx;
  color: #07c160;
}

/* 报警记录 */
.alert-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.section-count {
  font-size: 24rpx;
  color: #ff3b30;
  background: #fff0f0;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.alert-list {
  max-height: 400rpx;
  overflow-y: auto;
}

.alert-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.alert-item:last-child {
  border-bottom: none;
}

.alert-icon {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff0f0;
  border-radius: 50%;
}

.alert-content {
  flex: 1;
}

.alert-message {
  display: block;
  font-size: 28rpx;
  color: #333;
}

.alert-time {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.alert-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
  color: #ccc;
}

.alert-empty text {
  margin-top: 16rpx;
  font-size: 28rpx;
}

.btn-clear {
  margin-top: 20rpx;
  padding: 16rpx 0;
  background: #f5f5f5;
  border-radius: 40rpx;
  font-size: 28rpx;
  color: #999;
}

/* 安全提示 */
.security-tip {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  padding: 20rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #999;
  line-height: 1.6;
}

/* 骑行模式提示 */
.riding-hint {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  background: #fff;
  border-radius: 16rpx;
}

.hint-title {
  display: block;
  margin-top: 24rpx;
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.hint-desc {
  display: block;
  margin-top: 12rpx;
  font-size: 28rpx;
  color: #999;
}