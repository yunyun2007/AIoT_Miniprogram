<view class="container">
  <!-- 实时速度（大数字） -->
  <view class="speed-section">
    <view class="speed-value">{{speed}}</view>
    <text class="speed-unit">km/h</text>
  </view>

  <!-- 数据网格 -->
  <view class="data-grid">
    <view class="data-item">
      <text class="data-value">{{distance}}</text>
      <text class="data-label">公里</text>
    </view>
    <view class="data-item">
      <text class="data-value">{{formatTime(duration)}}</text>
      <text class="data-label">时长</text>
    </view>
    <view class="data-item">
      <text class="data-value">{{calories}}</text>
      <text class="data-label">千卡</text>
    </view>
    <view class="data-item">
      <text class="data-value">{{avgSpeed || 0}}</text>
      <text class="data-label">均速</text>
    </view>
  </view>

  <!-- 控制按钮 -->
  <view class="control-section">
    <block wx:if="{{!isTracking}}">
      <button class="btn-start" bindtap="startRide">开始骑行</button>
    </block>
    <block wx:else>
      <button class="btn-pause" bindtap="togglePause">
        {{isPaused ? '继续' : '暂停'}}
      </button>
      <button class="btn-stop" bindtap="stopRide">结束</button>
    </block>
  </view>

  <!-- 今日累计 -->
  <view class="today-summary" wx:if="{{!isTracking && distance > 0}}">
    <text>今日累计：{{distance}} 公里 | {{calories}} 千卡</text>
    <button class="btn-link" bindtap="viewMap">查看轨迹</button>
  </view>
</view>